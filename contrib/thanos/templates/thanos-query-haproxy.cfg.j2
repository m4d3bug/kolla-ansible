frontend thanos_query_front
    mode http
    http-request del-header X-Forwarded-Proto
    option httplog
    option forwardfor
    http-request set-header X-Forwarded-Proto https if { ssl_fc }
    bind {{ kolla_internal_vip }}:10903
    default_backend thanos_query_back

frontend thanos_query_external_front
    mode http
    http-request del-header X-Forwarded-Proto
    option httplog
    option forwardfor
    http-request set-header X-Forwarded-Proto https if { ssl_fc }
    bind 192.168.99.90:10903
    default_backend thanos_query_back

backend thanos_query_back
    mode http
    option httpchk GET /-/healthy HTTP/1.0
{% for host in groups['monitoring'] %}
    server {{ host }} {{ hostvars[host]['vxlan_ip'] | default(hostvars[host]['ansible_host']) }}:10903 check inter 2000 rise 2 fall 5
{% endfor %}
